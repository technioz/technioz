// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id              String   @id @default(uuid())
  externalId      String?  @unique @map("external_id")
  slug            String   @unique
  title           String
  excerpt         String?
  contentMarkdown String?  @map("content_markdown") @db.Text
  contentHtml     String?  @map("content_html") @db.Text
  metaDescription String?  @map("meta_description")
  category        String   @default("Insights")
  authorName      String   @default("Technioz Team") @map("author_name")
  authorRole      String   @default("Editorial") @map("author_role")
  featured        Boolean  @default(false)
  imageUrl        String?  @map("image_url")
  imageLocalPath  String?  @map("image_local_path")
  imageAlt        String?  @map("image_alt")
  publishedAt     DateTime @default(now()) @map("published_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  tags            Tag[]

  @@index([publishedAt])
  @@index([slug])
  @@map("articles")
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  articles  Article[]

  @@map("tags")
}
